# Server configuration
PORT=5000

# JSON Web Token secrets for short-lived access tokens and refresh tokens
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-at-least-64-character-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Firebase Admin SDK Service Account JSON configuration
# Tip: On Render, paste the entire contents of your service-account.json file as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}

# Optional bootstrap main admins. Leave unset to disable each account.
VINYAS_PASSWORD=
SHERA_PASSWORD=

# EmailJS Configuration (Proxy)
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=your-emailjs-private-key-here
