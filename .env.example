# Server configuration
PORT=5000

# JSON Web Token secret for authentication signing
JWT_SECRET=replace-this-with-a-long-random-string

# Firebase Admin SDK Service Account JSON configuration
# Tip: On Render, paste the entire contents of your service-account.json file as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}

# Secure main admin credentials (kept out of the frontend bundle)
MAIN_ADMIN_USERNAME=admin
MAIN_ADMIN_PASSWORD=change-this-password
MAIN_ADMIN_EMAIL=admin@gmail.com

# Additional portal main admins
VINYAS_PASSWORD=vinyas@123
SHERA_PASSWORD=shera@123

# EmailJS Configuration (Proxy)
EMAILJS_SERVICE_ID=service_a6calsj
EMAILJS_PUBLIC_KEY=Sdse_3EftZpcPBPYC
EMAILJS_PRIVATE_KEY=your-emailjs-private-key-here
